# ── Supabase ────────────────────────────────────────────────────
# Clé PUBLIQUE (anon key) — safe côté browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Clé SERVICE ROLE — côté serveur uniquement (route handlers), jamais exposée au client
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── OpenAI (côté serveur uniquement) ────────────────────────────
# Utilisée dans l'API Route /api/search pour générer l'embedding de la requête
OPENAI_API_KEY=your_openai_api_key_here
