# ── YouTube Data API ────────────────────────────────────────────
# Obtenir sur https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Supabase ────────────────────────────────────────────────────
# Obtenir sur https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Paramètres d'indexation ─────────────────────────────────────
# Taille des chunks en nombre de mots (~500 tokens ≈ 350 mots)
CHUNK_SIZE_WORDS=350
# Chevauchement entre chunks (pour ne pas couper le contexte)
CHUNK_OVERLAP_WORDS=50
# Langues à accepter pour les sous-titres (ordre de priorité)
TRANSCRIPT_LANGUAGES=fr,en
# Utiliser Whisper LOCAL si pas de sous-titres YouTube ? (true/false)
# Nécessite : pip install openai-whisper + brew install ffmpeg
USE_WHISPER_FALLBACK=false
# Modèle Whisper local : tiny | base | small | medium | large
# tiny=rapide/imprécis  small=bon compromis  large=lent/précis
WHISPER_MODEL=small
